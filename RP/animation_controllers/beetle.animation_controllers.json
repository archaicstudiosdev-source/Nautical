{
	"format_version": "1.19.0",
	"animation_controllers": {
		"controller.animation.beetle.main": {
			"initial_state": "idle",
			"states": {
				"fly": {
					"animations": ["fly"],
					"transitions": [
						{"idle": "query.is_on_ground && !query.is_moving"}
					],
					"blend_transition": 0.2,
					"blend_via_shortest_path": true
				},
				"idle": {
					"animations": ["idle"],
					"transitions": [
						{"fly": " !query.is_on_ground && query.is_moving"}
					],
					"blend_transition": 0.2,
					"blend_via_shortest_path": true
				}
			}
		}
	}
}